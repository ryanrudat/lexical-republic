# Required: long random secret for JWT signing — generate with `openssl rand -hex 32`
JWT_SECRET=

# JWT token lifetime (default 7d)
JWT_EXPIRES_IN=7d

# Database (Postgres connection string used by Prisma)
DATABASE_URL=

# Server
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
COOKIE_SAMESITE=lax

# Teacher self-registration secret. If unset, /api/auth/register-teacher returns 403.
TEACHER_REGISTRATION_CODE=

# OpenAI (Harmony moderation, PEARL feedback, AI generation)
OPENAI_API_KEY=
OPENAI_MODEL=

# Upload directory + size limits
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
MAX_VIDEO_FILE_SIZE=157286400
